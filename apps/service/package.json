    "test": "node --test --import tsx tests/**/*.test.ts"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "@obsidianlm/shared": "0.1.0",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
